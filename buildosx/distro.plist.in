<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>PT Indexim Coalindo</title>
    <background mime-type="image/png">
       ../buildosx/aisnesia418x620.png
    </background>
    <pkg-ref id="org.aisnesia"/>
    <options customize="never" require-scripts="false"/>
    <choices-outline>
        <line choice="default">
            <line choice="org.aisnesia"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="org.aisnesia" visible="false">
        <pkg-ref id="org.aisnesia"/>
    </choice>
    <allowed-os-versions>
        <os-version min="${CMAKE_OSX_DEPLOYMENT_TARGET}"/>
    </allowed-os-versions>
    <pkg-ref id="org.aisnesia" version="0" onConclusion="none">
        PT Indexim Coalindo.app.pkg
    </pkg-ref>
    <options hostArchitectures="${CMAKE_OSX_ARCHITECTURES_COMMA_SEP}" />
</installer-gui-script>

