0 ICON "..\\resources\\bitmaps\\aisnesia.ico"
1 VERSIONINFO
    FILEVERSION ${VERSION_MAJOR},${VERSION_MINOR},${VERSION_PATCH},0
    PRODUCTVERSION ${VERSION_MAJOR},${VERSION_MINOR}, 0, 0
    FILEFLAGSMASK 0
    FILEOS 0x00040004L
    FILETYPE 0x00000001L
    BEGIN
        BLOCK "StringFileInfo"
            BEGIN
                BLOCK "040904E4"
                    BEGIN
                        VALUE "CompanyName",      "PT Indexim Coalindo\0"
                        VALUE "FileDescription",  "Chart Plotter and Navigator\0"
                        VALUE "FileVersion",      "${VERSION_MAJOR},${VERSION_MINOR},${VERSION_PATCH}\0"
                        VALUE "InternalName",     "aisnesia.exe\0"
                        VALUE "LegalCopyright",   "GPL v2\0"
                        VALUE "OriginalFilename", "aisnesia.exe\0"
                        VALUE "ProductName",      "PT Indexim Coalindo\0"
                        VALUE "ProductVersion",   "${VERSION_MAJOR},${VERSION_MINOR}\0"
                    END
            END

        BLOCK "VarFileInfo"
            BEGIN

            END
    END
